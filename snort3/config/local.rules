# ============================================================
# IDS Project — Custom Snort3 Rules
# Attack types: DDoS, DoS, PortScan, BruteForce, Bot, WebAttack
# ============================================================

# --- DDoS Rules ---
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (
  msg:"DDoS: HTTP Flood Attack";
  flow:to_server;
  detection_filter:track by_src, count 500, seconds 10;
  sid:1000001; rev:1; priority:1;
  classtype:attempted-dos;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET 443 (
  msg:"DDoS: HTTPS Flood Attack";
  flow:to_server;
  detection_filter:track by_src, count 500, seconds 10;
  sid:1000002; rev:1; priority:1;
  classtype:attempted-dos;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"DDoS: TCP SYN Flood";
  flow:stateless;
  flags:S;
  detection_filter:track by_src, count 1000, seconds 5;
  sid:1000003; rev:1; priority:1;
  classtype:attempted-dos;
)

alert icmp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"DDoS: ICMP Flood";
  icode:0; itype:8;
  detection_filter:track by_src, count 500, seconds 5;
  sid:1000004; rev:1; priority:1;
  classtype:attempted-dos;
)

alert udp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"DDoS: UDP Flood";
  detection_filter:track by_src, count 1000, seconds 5;
  sid:1000005; rev:1; priority:1;
  classtype:attempted-dos;
)

# --- DoS Rules ---
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (
  msg:"DoS: Slowloris Attack";
  flow:to_server,established;
  content:"|0d0a|"; http_header;
  detection_filter:track by_src, count 100, seconds 30;
  sid:1000010; rev:1; priority:1;
  classtype:attempted-dos;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (
  msg:"DoS: HTTP Slow Read Attack";
  flow:to_server,established;
  dsize:<100;
  detection_filter:track by_src, count 200, seconds 30;
  sid:1000011; rev:1; priority:1;
  classtype:attempted-dos;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"DoS: TCP Connection Exhaustion";
  flow:to_server;
  flags:S;
  detection_filter:track by_src, count 500, seconds 10;
  sid:1000012; rev:1; priority:1;
  classtype:attempted-dos;
)

# --- PortScan Rules ---
alert tcp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"PortScan: TCP Port Scan";
  flow:to_server;
  flags:S;
  detection_filter:track by_src, count 50, seconds 2;
  sid:1000020; rev:1; priority:2;
  classtype:attempted-recon;
)

alert udp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"PortScan: UDP Port Scan";
  detection_filter:track by_src, count 50, seconds 2;
  sid:1000021; rev:1; priority:2;
  classtype:attempted-recon;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"PortScan: TCP SYN Stealth Scan";
  flow:stateless;
  flags:S;
  detection_filter:track by_src, count 100, seconds 1;
  sid:1000022; rev:1; priority:2;
  classtype:attempted-recon;
)

# --- BruteForce Rules ---
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (
  msg:"BruteForce: SSH Brute Force";
  flow:to_server,established;
  detection_filter:track by_src, count 30, seconds 10;
  sid:1000030; rev:1; priority:1;
  classtype:attempted-user;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET 21 (
  msg:"BruteForce: FTP Brute Force";
  flow:to_server,established;
  detection_filter:track by_src, count 30, seconds 10;
  sid:1000031; rev:1; priority:1;
  classtype:attempted-user;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET 3306 (
  msg:"BruteForce: MySQL Brute Force";
  flow:to_server,established;
  detection_filter:track by_src, count 20, seconds 10;
  sid:1000032; rev:1; priority:1;
  classtype:attempted-user;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET 3389 (
  msg:"BruteForce: RDP Brute Force";
  flow:to_server,established;
  detection_filter:track by_src, count 20, seconds 10;
  sid:1000033; rev:1; priority:1;
  classtype:attempted-user;
)

# --- Bot Rules ---
alert tcp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"Bot: IRC C&C Traffic";
  flow:to_server,established;
  content:"PRIVMSG|20|"; depth:100;
  within:100;
  sid:1000040; rev:1; priority:1;
  classtype:trojan-activity;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"Bot: HTTP C&C Beacon";
  flow:to_server,established;
  content:"GET"; http_method;
  content:"/gate.php"; http_uri;
  sid:1000041; rev:1; priority:1;
  classtype:trojan-activity;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"Bot: Botnet DNS Query";
  flow:to_server;
  content:"|01 00 00 01|"; depth:4; offset:2;
  sid:1000042; rev:1; priority:2;
  classtype:trojan-activity;
)

# --- WebAttack Rules ---
alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (
  msg:"WebAttack: SQL Injection Attempt";
  flow:to_server,established;
  content:"'"; http_uri;
  content:"OR"; http_uri; nocase;
  sid:1000050; rev:1; priority:1;
  classtype:web-application-attack;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (
  msg:"WebAttack: XSS Attempt";
  flow:to_server,established;
  content:"<script"; http_uri; nocase;
  content:">"; http_uri;
  sid:1000051; rev:1; priority:1;
  classtype:web-application-attack;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET 443 (
  msg:"WebAttack: SQL Injection Over HTTPS";
  flow:to_server,established;
  content:"' OR 1=1"; fast_pattern;
  sid:1000052; rev:1; priority:1;
  classtype:web-application-attack;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (
  msg:"WebAttack: Path Traversal Attempt";
  flow:to_server,established;
  content:"../"; http_uri;
  sid:1000053; rev:1; priority:1;
  classtype:web-application-attack;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET 80 (
  msg:"WebAttack: Command Injection";
  flow:to_server,established;
  content:"cmd="; http_uri; nocase;
  sid:1000054; rev:1; priority:1;
  classtype:web-application-attack;
)
